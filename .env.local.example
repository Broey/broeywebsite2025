NEXT_PUBLIC_SITE_URL=https://broey.com

# Private staging gate. Use SITE_VISIBILITY=private on preview deployments.
SITE_VISIBILITY=public
SITE_PASSCODE=

# Newsletter / MailerLite setup.
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=
MAILERLITE_SENDER_NAME=Broey.
MAILERLITE_SENDER_EMAIL=updates@broey.net
MAILERLITE_REPLY_TO_EMAIL=broey@broey.net

# Contact form email delivery and Cloudflare Turnstile.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Broey Website
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

BROEY_RELEASE_ROOT=D:\Broey\Releases\Already Released
SHOPIFY_STORE_DOMAIN=broey-beats.myshopify.com
SHOPIFY_MERCH_COLLECTION_HANDLE=broey-site-merch
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_MERCH_DEBUG_SOURCE=
